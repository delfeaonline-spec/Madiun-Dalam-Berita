rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /news/{id} {
      allow read, write: if true;
    }
    match /jobs/{id} {
      allow read, write: if true;
    }
    match /umkm/{id} {
      allow read, write: if true;
    }
    match /reports/{id} {
      allow read, write: if true;
    }
    match /viralFeed/{id} {
      allow read, write: if true;
    }
    match /settings/{id} {
      allow read, write: if true;
    }
    match /rssCache/{id} {
      allow read, write: if true;
    }
  }
}
